{
  "name": "scriptlint",
  "version": "0.1.0",
  "description": "ScriptLint is a local-first TypeScript CLI that scans shell scripts (bash, zsh, fish) across a project for anti-patterns, security.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "scriptlint": "./src/index.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "node --check src/index.js",
    "test": "node --test",
    "smoke": "node src/index.js --help && node src/index.js --version",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/scriptlint.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/scriptlint/issues"
  },
  "homepage": "https://github.com/rogerchappel/scriptlint#readme"
}
